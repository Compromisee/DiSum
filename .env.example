# ─────────────────────────────────────────────────────────
#  Discord Morning Bot — Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Discord ───────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# The channel ID where morning digests are posted
# Right-click a channel in Discord (with Developer Mode on) → Copy ID
DISCORD_CHANNEL_ID=your_channel_id_here

# ── Schedule ──────────────────────────────────────────────
# Cron expression for when to send the digest (default: 8:00 AM)
# Format: "minute hour * * *"
MORNING_CRON=0 8 * * *

# Your timezone (see: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TIMEZONE=America/Toronto

# ── Weather — OpenWeatherMap ──────────────────────────────
# Free API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# City name for weather
WEATHER_CITY=Toronto

# ── News — NewsAPI ────────────────────────────────────────
# Free API key (500 req/day) from https://newsapi.org/register
NEWS_API_KEY=your_newsapi_key_here

# Country code: ca, us, gb, etc.
NEWS_COUNTRY=ca

# Category: general, sports, technology, business, entertainment, health, science
NEWS_CATEGORY=general

# ── Soccer — API-Football (via RapidAPI) ─────────────────
# Get a free key at https://rapidapi.com/api-sports/api/api-football
# Free tier: 100 requests/day
API_FOOTBALL_KEY=your_api_football_key_here

# Comma-separated league IDs to show scores for:
#   39  = Premier League
#   140 = La Liga
#   61  = Ligue 1
#   78  = Bundesliga
#   135 = Serie A
#   2   = UEFA Champions League
#   3   = UEFA Europa League
SOCCER_LEAGUE_IDS=39,140,2

# League ID for top-scorers stats widget
SOCCER_STATS_LEAGUE=39

# Current season year (e.g. 2024 for the 2024/25 season)
SOCCER_SEASON=2024

# ── Google Calendar ───────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable "Google Calendar API"
# 3. Create OAuth 2.0 credentials (Desktop app)
# 4. Download the JSON → save as google-credentials.json next to this file
# 5. Run: node setup-google.js  (one-time authorization)
# (No env vars needed here — the credentials files handle auth)
